<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!--
        Increasing the canvas size by another 1.5x (to 243dp).
    -->
    <item
        android:width="243dp"
        android:height="243dp">
        <color android:color="@android:color/transparent" />
    </item>

    <!--
        Increasing the logo size by another 1.5x (to 243dp x 137dp).
        Note: This is significantly larger than the standard 108dp canvas
        and will likely be clipped by system masks.
    -->
    <item
        android:gravity="center"
        android:width="243dp"
        android:height="137dp">
        <bitmap
            android:src="@drawable/homeiot_logo"
            android:filter="true" />
    </item>
</layer-list>